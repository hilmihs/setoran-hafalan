# ── Database (PostgreSQL langsung — bukan lagi Supabase) ──
# Koneksi ke Postgres 17 tujuan. App bicara langsung ke DB via node-postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/maahir

# ── Storage audio (filesystem lokal — bukan lagi Supabase Storage) ──
# Folder tempat file audio disimpan. File ada di ${STORAGE_DIR}/${bucket}/${path}.
# Restore audio lama: taruh isi _backup_supabase/storage/setoran-audio ke
# ${STORAGE_DIR}/setoran-audio.
STORAGE_DIR=/var/www/html/maahir/storage
SUPABASE_AUDIO_BUCKET=setoran-audio

# Iron-session cookie secret — generate dengan: openssl rand -base64 32.
# JUGA dipakai menandatangani signed URL audio (/api/audio).
SESSION_SECRET=ganti-dengan-32-karakter-acak-yang-panjang-sekali

# Untuk wa.me link generation. WAJIB di-set ke domain produksi supaya
# link yang dikirim ke peserta/musyrif via WhatsApp bisa dibuka di HP.
NEXT_PUBLIC_APP_URL=https://maahir.muhajirproject.org

# ── Maintenance mode (opsional) ──
# MAINTENANCE_MODE=auto|on|off (default auto: aktif bila now >= MAINTENANCE_START)
# MAINTENANCE_START=2026-07-13T00:00:00+07:00
# MAINTENANCE_BYPASS_TOKEN=rahasia   # admin akses via ?maintenance_bypass=rahasia

# ── Admin DB console / API (opsional) ──
# Endpoint SQL admin /api/admin/db + CLI `npm run db`. Untuk kelola DB prod
# (query/CRUD/DDL) tanpa SSH. MATI secara default — set keduanya untuk aktif.
#   ADMIN_DB_API=on          master-switch (selain 'on' → endpoint 404)
#   ADMIN_API_TOKEN=<rahasia panjang>   bearer token; generate: openssl rand -base64 48
# Di server prod: set via Azure Variable Group (ENV_ADMIN_DB_API / ENV_ADMIN_API_TOKEN).
# Di .env.local (untuk `npm run db`): ADMIN_API_TOKEN (sama dgn prod) + ADMIN_API_URL.
# ADMIN_DB_API=on
# ADMIN_API_TOKEN=ganti-dengan-token-acak-panjang
# ADMIN_API_URL=https://maahir.muhajirproject.org   # target `npm run db` (fallback NEXT_PUBLIC_APP_URL)
